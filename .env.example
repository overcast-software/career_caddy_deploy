# Career Caddy — one-box quickstart environment.
# Copy to .env and fill in values:  cp .env.example .env
# .env is gitignored and loaded automatically by docker compose.

# ── Database ──────────────────────────────────────────────────────────────
# Local-only Postgres. Any non-empty password works on a single box.
DB_NAME=job_hunting
DB_USER=postgres
DB_PASSWORD=change-me-postgres

# ── Django ────────────────────────────────────────────────────────────────
# Generate a real value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-secure-random-value

# The port the app is served on (http://localhost:<HTTP_PORT>).
HTTP_PORT=8080

# If you serve this on a real hostname, add it here (comma-separated) and set
# CSRF_TRUSTED_ORIGINS / FRONTEND_URL / INSTANCE_ORIGIN to the public URL.
# ALLOWED_HOSTS=localhost,127.0.0.1,api
# CSRF_TRUSTED_ORIGINS=http://localhost:8080
# FRONTEND_URL=http://localhost:8080
# INSTANCE_ORIGIN=http://localhost:8080

# ── Email (optional) ──────────────────────────────────────────────────────
# Default backend logs mail to the container console — good enough to click
# through the app. To send real invite/password-reset mail, set SMTP creds:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@example.com

# ── AI (optional) ─────────────────────────────────────────────────────────
# Not needed for manual job-hunt tracking. Only set these if you wire up the
# full service tier (scraping / AI scoring / chat) — see terraform/.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Image tag ─────────────────────────────────────────────────────────────
# Pin to a release tag for reproducibility; `latest` tracks the newest build.
IMAGE_TAG=latest
